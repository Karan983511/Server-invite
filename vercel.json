{
  "buildCommand": "pnpm --filter @workspace/karan run build",
  "outputDirectory": "artifacts/karan/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "artifacts/api-server/src/**,lib/api-zod/src/**,lib/db/src/**"
    }
  }
}
